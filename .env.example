TZ=America/Guayaquil
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8085

# --- Catalogo y lineas de negocio ---
APP_CATALOG_REFRESH_FIXED_DELAY_MS=21600000
APP_CATALOG_REFRESH_INITIAL_DELAY_MS=30000
APP_BUSINESS_LINES_SOURCE=oracle
APP_BUSINESS_LINES_CACHE_TTL_HOURS=6
APP_BUSINESS_LINES_DEFAULT_REQUEST_CHAIN=1
APP_BUSINESS_LINES_DEFAULT_REQUEST_STORE=148
APP_BUSINESS_LINES_DEFAULT_REQUEST_STORE_NAME=FYBECA AMAZONAS
APP_BUSINESS_LINES_DEFAULT_REQUEST_POS=1
APP_BUSINESS_LINES_DEFAULT_REQUEST_CHANNEL_POS=POS

# --- Datasource Oracle TUKUNAFUNC (prod schema: IN_OMNI_*) ---
# Dejar sin definir en local para que el datasource no se active y el app levante en modo mock.
# APP_DATASOURCE_PROD_URL=jdbc:oracle:thin:@<host>:<port>:<sid>
# APP_DATASOURCE_PROD_USERNAME=TUKUNAFUNC
# APP_DATASOURCE_PROD_PASSWORD=

# --- Datasource Oracle RMS (gpf_lectura: AD_* + ITEM_MASTER) ---
# Dejar sin definir en local para que el datasource no se active y el app levante en modo mock.
# APP_DATASOURCE_RMS_URL=jdbc:oracle:thin:@<host>:<port>:<sid>
# APP_DATASOURCE_RMS_USERNAME=gpf_lectura
# APP_DATASOURCE_RMS_PASSWORD=

# --- Integraciones externas ---
APP_INTEGRATIONS_DEFAULT_CONNECT_TIMEOUT_MS=60000
APP_INTEGRATIONS_DEFAULT_READ_TIMEOUT_MS=60000
APP_INTEGRATIONS_TLS_PROTOCOLS=TLSv1.2
# En local se usa mock. Cambiar a false solo cuando se tiene acceso a los proveedores reales.
APP_INTEGRATIONS_MOCK_ENABLED=true
